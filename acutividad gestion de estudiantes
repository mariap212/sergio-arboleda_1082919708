def validar_cedula(cedula):
    return cedula.isdigit() and 8 <= len(cedula) <= 10

def validar_email(email):
    return '@' in email and '.' in email.split('@')[1]

def validar_calificaciones(calificaciones):
    return all(0 <= c <= 5 for c in calificaciones)

def calcular_promedio(calificaciones):
    return round(sum(calificaciones) / len(calificaciones), 2) if calificaciones else 0.0

def clasificar_desempeño(promedio):
    if promedio >= 4.5: return "Excelente"
    elif promedio >= 4.0: return "Muy bueno"
    elif promedio >= 3.5: return "Bueno"
    elif promedio >= 3.0: return "Satisfactorio"
    return "Necesita mejorar"

def crear_estudiante(cedula, nombre, email, calificaciones):
    if not validar_cedula(cedula): print("Cédula inválida."); return
    if not validar_email(email): print("Email inválido."); return
    if not validar_calificaciones(calificaciones): print("Calificaciones inválidas."); return
    promedio = calcular_promedio(calificaciones)
    return {"cedula": cedula, "nombre": nombre, "email": email, "promedio": promedio}

def listar_estudiantes(estudiantes):
    if not estudiantes: print("No hay estudiantes."); return
    print("Cédula      | Nombre               | Promedio | Desempeño")
    print("-" * 55)
    for e in estudiantes:
        print(f"{e['cedula']:<12} | {e['nombre']:<20} | {e['promedio']:<8} | {clasificar_desempeño(e['promedio'])}")

def main():
    estudiantes = []
    while True:
        print("\n1. Agregar\n2. Ver lista\n3. Buscar\n4. Salir")
        try:
            op = int(input("Opción: "))
            if op == 1:
                cedula = input("Cédula: ")
                nombre = input("Nombre: ")
                email = input("Email: ")
                calif = [float(x) for x in input("Calificaciones (coma): ").split(',')]
                e = crear_estudiante(cedula, nombre, email, calif)
                if e:
                    estudiantes.append(e)
                    print(f"Agregado. Promedio: {e['promedio']} | {clasificar_desempeño(e['promedio'])}")
            elif op == 2: listar_estudiantes(estudiantes)
            elif op == 3:
                c = input("Cédula: ")
                e = next((x for x in estudiantes if x["cedula"] == c), None)
                print(e if e else "No encontrado.")
            elif op == 4: break
            else: print("Opción inválida.")
        except: print("Error.")

if __name__ == "__main__": main()
